      <column-instance column='[estimated_value]' derivation='Avg' name='[avg:estimated_value:qk]' pivot='key' type='quantitative' />
      <column-instance column='[estimated_value]' derivation='Sum' name='[cum:sum:estimated_value:qk]' pivot='key' type='quantitative'>
        <table-calc aggregation='Sum' ordering-type='Rows' type='CumTotal' />
      </column-instance>
      <column-instance column='[estimated_value]' derivation='Median' name='[med:estimated_value:qk]' pivot='key' type='quantitative' />

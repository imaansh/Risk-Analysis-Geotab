      <aliases enabled='yes' />
      <column caption='Stage Order' datatype='integer' name='[Calculation_1611162834114088961]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [stage] = &quot;Engaged&quot; THEN 1&#13;&#10;ELSEIF [stage] = &quot;Collaborating&quot; THEN 2&#13;&#10;ELSEIF [stage] = &quot;Vendor Displacement&quot; THEN 3&#13;&#10;ELSEIF [stage] = &quot;Quotation&quot; THEN 4&#13;&#10;ELSEIF [stage] = &quot;Demo&quot; THEN 5&#13;&#10;ELSEIF [stage] = &quot;Contracting&quot; THEN 6&#13;&#10;END' />
      </column>
      <column caption='Deal Age' datatype='integer' name='[Calculation_1611162834219618306]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;, [created_date], TODAY())' />
      </column>
      <column caption='Age Bucket' datatype='string' name='[Calculation_1611162834219704323]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1611162834219618306] &lt;=30 THEN &quot;0-30 Days&quot;&#13;&#10;&#13;&#10;ELSEIF [Calculation_1611162834219618306] &lt;=60 THEN &quot;31-60 Days&quot;&#13;&#10;&#13;&#10;ELSEIF [Calculation_1611162834219618306] &lt;=90 THEN &quot;61-90 Days&quot;&#13;&#10;&#13;&#10;ELSE &quot;90+ Days&quot;&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='Win Rate' datatype='real' name='[Calculation_1611162834243297285]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM(IF [stage] = &quot;Closed Won&quot; THEN 1 ELSE 0 END)&#13;&#10;/&#13;&#10;SUM(IF [stage] IN (&quot;Closed Won&quot;, &quot;Closed Lost&quot;) THEN 1 ELSE 0 END)) * 100' />
      </column>
      <column caption='Current Quarter' datatype='datetime' name='[Calculation_1611162834254954503]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATETRUNC(&apos;quarter&apos;, TODAY())' />
      </column>
      <_.fcp.ObjectModelTableType.true...column caption='opportunities.csv' datatype='table' name='[__tableau_internal_object_id__].[opportunities.csv_CF68916CBAE4413E80FC3B7EFE443874]' role='measure' type='quantitative' />
      <column caption='Close Date' datatype='date' name='[close_date]' role='dimension' type='ordinal' />

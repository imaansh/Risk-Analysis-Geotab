      <column-instance column='[estimated_value]' derivation='Sum' name='[sum:estimated_value:qk]' pivot='key' type='quantitative' />
      <group hidden='true' name='[Exclusions (MONTH(Close Date),Stage)]' name-style='unqualified' user:auto-column='exclude'>
        <groupfilter function='crossjoin'>
          <groupfilter function='level-members' level='[mn:close_date:ok]' />
          <groupfilter function='level-members' level='[none:stage:nk]' />
        </groupfilter>
      </group>
      <group caption='Stage Set' name='[Stage Set]' name-style='unqualified' user:ui-builder='filter-group'>
        <groupfilter function='except' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate'>
          <groupfilter function='level-members' level='[stage]' />
          <groupfilter function='union'>
            <groupfilter function='member' level='[stage]' member='&quot;Closed Lost&quot;' />
            <groupfilter function='member' level='[stage]' member='&quot;Closed Won&quot;' />
            <groupfilter function='member' level='[stage]' member='%null%' />
          </groupfilter>
        </groupfilter>
      </group>
